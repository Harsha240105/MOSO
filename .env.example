# MOSO AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
MOSO_ENV=development
MOSO_LOG_LEVEL=debug
MOSO_DATA_DIR=./data

# Model Configuration
MOSO_LLM_MODEL=phi-3-mini-4k-instruct-q4.gguf
MOSO_LLM_MODEL_PATH=./models/llm/phi3/
MOSO_WHISPER_MODEL=base
MOSO_TTS_MODEL=coqui

# Memory Engine
MEMORY_ENGINE_ENABLED=true
MEMORY_VECTOR_DB=chroma
MEMORY_EMBEDDING_DIM=384
MEMORY_RAG_TOP_K=5

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_API_PREFIX=/api/v1

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=moso
POSTGRES_USER=moso
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sync
SYNC_SERVER_URL=http://localhost:8000
SYNC_ENABLED=false
SYNC_ENCRYPTION_KEY=

# Security
ENCRYPTION_ALGORITHM=AES-256-GCM
SECURE_ENCLAVE_ENABLED=false
ZERO_KNOWLEDGE_SYNC=false

# Cloud (optional)
CLOUDFLARE_TUNNEL_TOKEN=
FIREBASE_PROJECT_ID=
